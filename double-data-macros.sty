% Cells in double categories.
\RequirePackage{quiver}
\newcommand{\inlineCell}[1][small]{%
  \def\tempa{#1}%
  \inlineCellContinued
}
\newcommand{\inlineCellContinued}[9]{%
% https://q.uiver.app/?
\begin{tikzcd}[ampersand replacement=\&, cramped, row sep=small, column sep=\tempa]
  {#1} \& {#2} \\
  {#3} \& {#4}
  \arrow[""{name=0, anchor=center, inner sep=0}, "{#5}", "\shortmid"{marking}, from=1-1, to=1-2]
  \arrow["{#7}"', from=1-1, to=2-1]
  \arrow["{#8}", from=1-2, to=2-2]
  \arrow[""{name=1, anchor=center, inner sep=0}, "{#6}"', "\shortmid"{marking}, from=2-1, to=2-2]
  \arrow["{#9}"{description}, draw=none, from=0, to=1]
\end{tikzcd}}
\newcommand{\stdInlineCell}[1]{\inlineCell{x}{y}{w}{z}{m}{n}{f}{g}{#1}}

