% lenses
\newcommand{\biglens}[2]{
    \begin{pmatrix}{\vphantom{f_f^f}#1} \\ {\vphantom{f_f^f}#2} \end{pmatrix}
}
\newcommand{\littlelens}[2]{
    \begin{psmallmatrix}{\vphantom{f}#1} \\ {\vphantom{f}#2} \end{psmallmatrix}
}
\newcommand{\lens}[2]{
  \relax\if@display
    \biglens{#1}{#2}
  \else
    \littlelens{#1}{#2}
  \fi
}



